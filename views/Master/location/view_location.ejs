<%- include('../../layout/header') %>
<%- include('../../layout/sidebar') %>

<main id="main" class="main">
   <% if (permissions.includes(39)) { %> 

    <div class="text-left m-4">
        <a href="/add_location" class="btn btn-primary login-btn"><i class="bi bi-plus-lg"></i> Add Location</a>
    </div>

    <section class="section dashboard">
        <div class="row">
            <div class="col-12">
                <div class="card top-selling overflow-auto">
                   

                    <div class="card-body pb-0">
                        <h5 class="card-title">All Locations</h5>
                        <div class="mb-3">
                            <button type="button" class="btn btn-danger mb-2 d-none" id="deleteSelectedBtn"><i class="bi bi-trash"></i> Delete Selected</button>
                        </div>
                        <table id="locationTable" class="table table-hover">
                            <thead>
                                <tr>
                                    <!-- <th>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="gridCheckAll">
                                            <label class="form-check-label" for="gridCheckAll"></label>
                                        </div>
                                    </th> -->
                                    <th scope="col">Sr No.</th>
                                    <th scope="col">City Name</th>
                                    <!--  <th scope="col">Status</th> -->
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% let i = 1; %>
                                <% if (locations && locations.length > 0) { %>
                                    <% locations.forEach(location => { %>
                                        <tr>
                                            <!-- <td>
                                                <div class="form-check">
                                                    <input class="form-check-input city-checkbox" type="checkbox" data-id="<%= location.id %>">
                                                    <label class="form-check-label" for="propertyCheck<%= location.id %>"></label>
                                                </div>
                                            </td> -->
                                            <td><%= i++ %></td>
                                            <td><%= location.name %></td>
                                             <!-- <td style="color: <%= location.status === 1 ? 'green' : 'red' %>;">
                                                 <%= location.status === 1 ? 'Active' : 'Deactive' %>
                                            </td> -->
                                             
                                            <td>
                                                <a href="/editlocation/<%= location.id %>" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                                                <button class="btn btn-sm btn-danger location" data-id="<%= location.id %>"><i class="bi bi-trash"></i></button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                    
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" style="text-align: center;" class="mt-4">No Location found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                        <% } else { %>
                  <img src="https://builder.propal.in/Images/access_denied.png" alt="No Permission" style="max-width: 100%; height: auto;" />
                  <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../../layout/footer') %>



<script>
document.addEventListener('DOMContentLoaded', () => {
    const propertyTable = $('#propertyTable').DataTable({
        responsive: true
    });

    propertyTable.on('init.dt', function () {
        $('.dataTables_filter').addClass('d-none');
        $('.dataTables_length').addClass('d-none');
    });

    $('#locationTable').on('click', '.location', async function () {
        const id = $(this).data('id');
        try {
            const response = await fetch(`/delete_location/${id}`, {
                method: 'DELETE'
            });
            const data = await response.json();
            if (response.ok) {
                await Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: 'Location deleted successfully',
                    timer: 1500,
                    timerProgressBar: true,
                    didClose: () => {
                        setTimeout(() => {
                            window.location.reload();
                        }, 500); 
                    }
                });
            } else {
                await Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to delete Location.'
                });
            }
        } catch (error) {
            console.error('Error:', error);
            await Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to delete location.'
            });
        }
    });



 
});


</script>
