<%- include('../../layout/header') %>
<%- include('../../layout/sidebar') %>

<main id="main" class="main">
    <div class="card" style="padding:20px 0;">
        <div class="card-body">
            <h5 class="card-title">Add Society Type</h5>
            <form class="row g-3" id="multiStepForm" enctype="multipart/form-data">

                <div class="col-md-12">
                    <label for="inputPassword5" class="form-label">Society Type<span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="inputsocietytype" name="name" required>
                    <div class="invalid-feedback">Please enter a Society Type.</div>
                </div>

                <div class="col-md-12" style="margin: 30px 0;">
                    <label class="form-label" for="customFile">Upload Image<span class="text-danger">*</span></label>
                    <input type="file" class="form-control" id="inputsocietyImage" name="image" required/>
                    <div class="invalid-feedback">Please upload an image.</div>
                </div>

                <div class="text-center">
                    <button type="button" class="btn btn-primary" id="submitFormButton">Submit</button>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('../../layout/footer') %>
<script>
    $(document).ready(function () {
        $('#submitFormButton').click(function () {
            // Reset previous validation state
            $('#inputsocietytype').removeClass('is-invalid');
            $('#inputsocietyImage').removeClass('is-invalid');
            $('.invalid-feedback').hide();

            // Validate Society Type
            if ($('#inputsocietytype').val().trim() === '') {
                $('#inputsocietytype').addClass('is-invalid');
                $('#inputsocietytype').next('.invalid-feedback').show();
                return; // Exit function if validation fails
            }

            // Validate Image Upload
            let imageUpload = $('#inputsocietyImage')[0].files[0];
            if (!imageUpload) {
                $('#inputsocietyImage').addClass('is-invalid');
                $('#inputsocietyImage').next('.invalid-feedback').show();
                return; // Exit function if validation fails
            }

            // Form Data Submission
            let formData = new FormData();
            formData.append('name', $('#inputsocietytype').val());
            formData.append('image', imageUpload);
    
            $.ajax({
                url: '/save_society_type',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response.message,
                        }).then(function() {
                            window.location.href = '/view_society_type';
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message,
                        });
                    }
                },
                error: function (xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'An error occurred: ' + xhr.responseText
                    });
                }
            });
        });
    });
</script>
