<%- include('../../layout/header') %>
<%- include('../../layout/sidebar') %>

<main id="main" class="main">
   <% if (permissions.includes(39)) { %> 

    <div class="text-left m-4">
        <a href="/add_society_type" class="btn btn-primary login-btn"><i class="bi bi-plus-lg"></i> Add Society Type</a>
    </div>

    <section class="section dashboard">
        <div class="row">
            <div class="col-12">
                <div class="card top-selling overflow-auto">
                   

                    <div class="card-body pb-0">
                        <h5 class="card-title">All Society Type</h5>
                        <div class="mb-3">
                            <button type="button" class="btn btn-danger mb-2 d-none" id="deleteSelectedBtn"><i class="bi bi-trash"></i> Delete Selected</button>
                        </div>
                        <table id="societyTable" class="table table-hover">
                            <thead>
                                <tr>
                                    <!-- <th>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="gridCheckAll">
                                            <label class="form-check-label" for="gridCheckAll"></label>
                                        </div>
                                    </th> -->
                                    <th scope="col">Sr No.</th>
                                    <th scope="col">Society Type</th>
                                    <th scope="col">Image</th>
                                   <!--   <th scope="col">Status</th> -->
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% let i = 1; %>
                                <% if (society_types && society_types.length > 0) { %>
                                    <% society_types.forEach(society_type => { %>
                                        <tr>
                                            <!-- <td>
                                                <div class="form-check">
                                                    <input class="form-check-input city-checkbox" type="checkbox" data-id="<%= society_type.id %>">
                                                    <label class="form-check-label" for="propertyCheck<%= society_type.id %>"></label>
                                                </div>
                                            </td> -->
                                            <td><%= i++ %></td>
                                            <td><%= society_type.name %></td>
                                            <td class="fw-bold"><img src="<%= baseUrl + 'Images/type_of_society/' + society_type.image %>"></td>
                                             <!-- <td style="color: <%= society_type.status === 1 ? 'green' : 'red' %>;">
                                                 <%= society_type.status === 1 ? 'Active' : 'Deactive' %>
                                            </td> -->
                                            
                                            <td>
                                                <a href="/editsocietytype/<%= society_type.id %>" class="btn btn-sm btn-primary"><i class="bi bi-pencil"></i></a>
                                                <button class="btn btn-sm btn-danger societytype" data-id="<%= society_type.id %>"><i class="bi bi-trash"></i></button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                    
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" style="text-align: center;" class="mt-4">No Society Type found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                        <% } else { %>
                  <img src="https://builder.propal.in/Images/access_denied.png" alt="No Permission" style="max-width: 100%; height: auto;" />
                  <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('../../layout/footer') %>


<script>
document.addEventListener('DOMContentLoaded', () => {
    // Initialize DataTable
    const societyTable = $('#societyTable').DataTable({
        responsive: true
    });

    // Hide DataTable search box and page length selector
    societyTable.on('init.dt', function () {
        $('.dataTables_filter').addClass('d-none');
        $('.dataTables_length').addClass('d-none');
    });

    // Event delegation for individual Delete buttons
    $('#societyTable').on('click', '.societytype', async function () {
        const id = $(this).data('id');
        try {
            const response = await fetch(`/delete_society_type/${id}`, {
                method: 'DELETE'
            });
            const data = await response.json();
            if (response.ok) {
                await Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: 'Society Type deleted successfully',
                    timer: 1500,
                    timerProgressBar: true,
                    didClose: () => {
                        setTimeout(() => {
                            window.location.reload();
                        }, 500); 
                    }
                });
            } else {
                await Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to delete Society Type.'
                });
            }
        } catch (error) {
            console.error('Error:', error);
            await Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to delete Society Type.'
            });
        }
    });



 
});


</script>
