<%- include('../../layout/header') %>
<%- include('../../layout/sidebar') %>

<main id="main" class="main">
    <div class="card" style="padding:20px 0;">
        <div class="card-body">
            <h5 class="card-title">Add Estimated Size</h5>
            <form class="row g-3" id="multiStepForm" enctype="multipart/form-data">

                <div class="col-md-12">
                    <label for="inputestimated_sizes" class="form-label">Estimated Size<span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="inputestimated_sizes" name="name">
                    <div class="invalid-feedback">
                        Estimated Size cannot be empty.
                    </div>
                </div>

                <div class="text-center">
                    <button type="button" class="btn btn-primary" id="submitFormButton">Submit</button>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('../../layout/footer') %>

<script>
    $(document).ready(function () {
        $('#submitFormButton').click(function () {

            // Reset any previous error messages
            $('#inputestimated_sizes').removeClass('is-invalid');
            $('.invalid-feedback').hide();

            // Validate Flat Space Name
            if ($('#inputestimated_sizes').val().trim() === '') {
                $('#inputestimated_sizes').addClass('is-invalid');
                $('#inputestimated_sizes').next('.invalid-feedback').show();
                return; // Exit function if validation fails
            }

            // Form Data Submission
            let formData = new FormData();
            formData.append('name', $('#inputestimated_sizes').val());

            // AJAX request to submit form data
            $.ajax({
                url: '/save_estimated_sizes',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response.message,
                        }).then(function () {
                            window.location.href = '/view_estimated_sizes';
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.message,
                        });
                    }
                },
                error: function (xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'An error occurred: ' + xhr.responseText
                    });
                }
            });
        });
    });
</script>
