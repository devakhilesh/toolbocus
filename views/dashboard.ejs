<%- include('layout/header') %>
<%- include('layout/sidebar') %>

<main id="main" class="main">

  <section class="section dashboard">
    <div class="row">

      <!-- Cards Section -->
      <div class="col-lg-12">
        <div class="row">

          <!-- Total Views Card -->
          <div class="col-lg-3 col-md-6">
            <div class="card info-card sales-card">
              <div class="card-body">
                <h5 class="card-title">Total Views</h5>
                <div class="d-flex align-items-center">
                  <div class="p">
                    <h6>0</h6>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Total Enquiries Card -->
          <div class="col-lg-3 col-md-6">
            <div class="card info-card revenue-card">
              <div class="card-body">
                <h5 class="card-title">Total Enquiries</h5>
                <div class="d-flex align-items-center">
                  <div class="p">
                    <h6>0</h6>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Inventory Count Card -->
          <div class="col-lg-3 col-md-6">
            <div class="card info-card revenue-card">
              <div class="card-body">
                <h5 class="card-title">Inventory Count</h5>
                <div class="d-flex align-items-center">
                  <div class="p">
                    <h6>0</h6>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Scheduled Visits Card -->
          <div class="col-lg-3 col-md-6">
            <div class="card info-card customers-card">
              <div class="card-body">
                <h5 class="card-title">Scheduled Visits</h5>
                <div class="d-flex align-items-center">
                  <div class="p">
                    <h6>0</h6>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Top Properties Table -->
      <div class="col-12 mt-4">
        <div class="card top-selling overflow-auto">
          <div class="card-body pb-0">
            <h5 class="card-title">Top Properties</h5>
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>SR No.</th>
                  <th>Name</th>
                  <th>Location</th>
                  <th>Price</th>
                  <th>Status</th>
                  <th>Propal Suggest</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="7" style="text-align:center;">No data available</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </section>

</main>


<%- include('layout/footer') %>